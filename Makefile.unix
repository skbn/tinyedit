# (at your option) any later version.
#
# Makefile.unix -- Build tinyedit for Linux/BSD/macOS
#
# Position-independent: anchored to the directory containing this Makefile,
# so it works regardless of the CWD it is invoked from
# (e.g. `make -f path/to/Makefile.unix` or `make -C path/to ...`).

# Directory of this Makefile (with trailing slash)
HERE := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))

# Feature selection options (set to 1 to enable)
USE_HUNSPELL ?= 0
USE_HYPHEN ?= 0
USE_MYTHES ?= 0
USE_GRAMMAR ?= 0
USE_TRANSLATE ?= 0
USE_STARDICT ?= 0
USE_TTS ?= 0

# Detect OS and warn if BSD make is used instead of gmake
OS := $(shell uname -s)
BSD_OS := $(filter FreeBSD NetBSD OpenBSD,$(OS))

ifneq ($(BSD_OS),)
    ifeq ($(MAKE),make)
        $(warning On BSD systems, use 'gmake' instead of 'make' for this Makefile)
    endif
endif

CC ?= cc
CXX ?= c++
CFLAGS += -I$(HERE).. -I$(HERE) -I$(HERE)core -I$(HERE)components -I$(HERE)ui -Wall -Wextra -Wpedantic -Wmissing-prototypes -Wstrict-prototypes -Wdeclaration-after-statement -Wimplicit-function-declaration -Wno-unused-parameter -std=gnu89 -O2 -D_XOPEN_SOURCE_EXTENDED
CXXFLAGS += -I$(HERE).. -I$(HERE) -I$(HERE)core -I$(HERE)components -I$(HERE)ui -std=c++14 -O2 -Wall -Wextra -Wpedantic -Wno-unused-parameter
AR = ar

# Platform define
CDEFS = -DPLATFORM_UNIX
ifneq ($(BSD_OS),)
  CDEFS += -DPLATFORM_BSD
endif

# Hunspell support (uses system library on Unix)

ifeq ($(USE_HUNSPELL),1)
  CFLAGS += -DHAVE_HUNSPELL -I$(HERE)spell
  CDEFS += -DHAVE_HUNSPELL

  # Use pkg-config if available (most reliable, especially for NetBSD)
  HUNSPELL_PKG_CONFIG_CFLAGS := $(shell pkg-config --cflags hunspell 2>/dev/null)
  HUNSPELL_PKG_CONFIG_LIBS := $(shell pkg-config --libs hunspell 2>/dev/null)

  ifneq ($(HUNSPELL_PKG_CONFIG_LIBS),)
    CFLAGS += $(HUNSPELL_PKG_CONFIG_CFLAGS)
    HUNSPELL_LIB = $(HUNSPELL_PKG_CONFIG_LIBS)
  else
    # Fallback to platform-specific paths
    ifeq ($(OS),NetBSD)
      CFLAGS += -I/usr/pkg/include
      HUNSPELL_LIB = -L/usr/pkg/lib -Wl,-rpath,/usr/pkg/lib -lhunspell-1.7
    else ifeq ($(OS),FreeBSD)
      CFLAGS += -I/usr/local/include
      HUNSPELL_LIB = -L/usr/local/lib -Wl,-rpath,/usr/local/lib -lhunspell-1.7
    else ifeq ($(OS),OpenBSD)
      CFLAGS += -I/usr/local/include
      HUNSPELL_LIB = -L/usr/local/lib -Wl,-rpath,/usr/local/lib -lhunspell-1.7
    else
      HUNSPELL_LIB = -lhunspell
    endif
  endif
  SPELL_OBJS = $(OBJDIR)/spell.o
endif

# Hyphenation support (libhyphen)
ifeq ($(USE_HYPHEN),1)
  ifeq ($(USE_HUNSPELL),0)
    $(error USE_HYPHEN=1 requires USE_HUNSPELL=1)
  endif
  CFLAGS += -DHAVE_HYPHEN -I$(HERE)hyph_wrap
  CDEFS += -DHAVE_HYPHEN

  HYPHEN_PKG_CONFIG_CFLAGS := $(shell pkg-config --cflags hyphen 2>/dev/null)
  HYPHEN_PKG_CONFIG_LIBS   := $(shell pkg-config --libs   hyphen 2>/dev/null)

  ifneq ($(HYPHEN_PKG_CONFIG_LIBS),)
    CFLAGS += $(HYPHEN_PKG_CONFIG_CFLAGS)
    HYPHEN_LIB = $(HYPHEN_PKG_CONFIG_LIBS)
  else
    ifeq ($(OS),NetBSD)
      CFLAGS += -I/usr/pkg/include
      HYPHEN_LIB = -L/usr/pkg/lib -Wl,-rpath,/usr/pkg/lib -lhyphen
    else ifeq ($(OS),FreeBSD)
      CFLAGS += -I/usr/local/include
      HYPHEN_LIB = -L/usr/local/lib -Wl,-rpath,/usr/local/lib -lhyphen
    else ifeq ($(OS),OpenBSD)
      CFLAGS += -I/usr/local/include
      HYPHEN_LIB = -L/usr/local/lib -Wl,-rpath,/usr/local/lib -lhyphen
    else
      HYPHEN_LIB = -lhyphen
    endif
  endif
  HYPH_OBJS = $(OBJDIR)/hyph.o
endif

# Thesaurus support (mythes; C++)
ifeq ($(USE_MYTHES),1)
  ifeq ($(USE_HUNSPELL),0)
    $(error USE_MYTHES=1 requires USE_HUNSPELL=1)
  endif
  CFLAGS += -DHAVE_MYTHES -I$(HERE)thes
  CDEFS += -DHAVE_MYTHES

  MYTHES_PKG_CONFIG_CFLAGS := $(shell pkg-config --cflags mythes 2>/dev/null)
  MYTHES_PKG_CONFIG_LIBS   := $(shell pkg-config --libs   mythes 2>/dev/null)

  ifneq ($(MYTHES_PKG_CONFIG_LIBS),)
    CFLAGS += $(MYTHES_PKG_CONFIG_CFLAGS)
    CXXFLAGS += $(MYTHES_PKG_CONFIG_CFLAGS)
    MYTHES_LIB = $(MYTHES_PKG_CONFIG_LIBS)
  else
    ifeq ($(OS),NetBSD)
      CFLAGS += -I/usr/pkg/include
      CXXFLAGS += -I/usr/pkg/include
      MYTHES_LIB = -L/usr/pkg/lib -Wl,-rpath,/usr/pkg/lib -lmythes-1.2
    else ifeq ($(OS),FreeBSD)
      CFLAGS += -I/usr/local/include
      CXXFLAGS += -I/usr/local/include
      MYTHES_LIB = -L/usr/local/lib -Wl,-rpath,/usr/local/lib -lmythes-1.2
    else ifeq ($(OS),OpenBSD)
      CFLAGS += -I/usr/local/include
      CXXFLAGS += -I/usr/local/include
      MYTHES_LIB = -L/usr/local/lib -Wl,-rpath,/usr/local/lib -lmythes-1.2
    else
      MYTHES_LIB = -lmythes-1.2
    endif
  endif
  THES_OBJS = $(OBJDIR)/thes.o
endif

# Grammar checker support (small, self-contained C module, no external deps)
ifeq ($(USE_GRAMMAR),1)
  CFLAGS += -DHAVE_GRAMMAR -I$(HERE)grammar
  CDEFS += -DHAVE_GRAMMAR
  GRAMMAR_OBJS = $(OBJDIR)/grammar_utils.o \
                 $(OBJDIR)/grammar_cache.o \
                 $(OBJDIR)/grammar_rules.o \
                 $(OBJDIR)/grammar_core.o  \
                 $(OBJDIR)/grammar_api.o   \
                 $(OBJDIR)/ui_grammar.o
endif

# Translator support (HTTP backends via libcurl on Unix/Windows, external curl on Amiga)
ifeq ($(USE_TRANSLATE),1)
  CFLAGS += -DHAVE_TRANSLATE -DHAVE_TRANSLATE_HTTP -I$(HERE)translate
  CDEFS += -DHAVE_TRANSLATE -DHAVE_TRANSLATE_HTTP
  TRANSLATE_OBJS = $(OBJDIR)/translate.o $(OBJDIR)/translate_http.o $(OBJDIR)/http_client.o $(OBJDIR)/json_utils.o
  # Use pkg-config for libcurl on Unix (multi-platform detection)
  TRANSLATE_CFLAGS = $(shell pkg-config --cflags libcurl 2>/dev/null)
  TRANSLATE_LIB = $(shell pkg-config --libs libcurl 2>/dev/null)
  # Fallback to -lcurl if pkg-config fails
  ifeq ($(TRANSLATE_LIB),)
    TRANSLATE_LIB = -lcurl
  endif
  CFLAGS += $(TRANSLATE_CFLAGS)

  # StarDict offline backend (pure C, no extra library)
  ifeq ($(USE_STARDICT),1)
    CFLAGS += -DHAVE_TRANSLATE_STARDICT
    CDEFS += -DHAVE_TRANSLATE_STARDICT
    TRANSLATE_OBJS += $(OBJDIR)/translate_stardict.o
  endif
endif

# Text-To-Speech support. Zero build-time dependency: the module spawns
# espeak-ng (or espeak, or macOS `say`, or festival) as a subprocess.
# At runtime the user needs one of those in $PATH. Nothing to link.
ifeq ($(USE_TTS),1)
  CFLAGS += -DHAVE_TTS -I$(HERE)tts
  CDEFS += -DHAVE_TTS
  TTS_OBJS = $(OBJDIR)/tts.o $(OBJDIR)/tts_espeak.o
endif

# ncurses library detection:
#   Linux, FreeBSD, NetBSD, OpenBSD  -> -lncursesw   (wide-char variant)
#   macOS (Darwin)                   -> -lncurses     (system curses is wide-capable)
# Override by passing NCURSES_LIB=... on the command line if needed.
ifeq ($(OS),Darwin)
    NCURSES_LIB ?= -lncurses
else ifeq ($(BSD_OS),)
    NCURSES_LIB ?= -lncursesw
else
    # BSD: default to ncursesw, but can be overridden
    NCURSES_LIB ?= -lncursesw
endif
TARGET = $(HERE)libtinyedit-unix.a

# Directories -- separate obj dir from Amiga build so .o files don't collide
OBJDIR = $(HERE)objs.unix
COREDIR = $(HERE)core
COMPDIR = $(HERE)components
UIDIR = $(HERE)ui

# Object files in objs/
CORE_OBJS = $(OBJDIR)/charset.o $(OBJDIR)/clipboard.o $(OBJDIR)/keys.o \
            $(OBJDIR)/search.o $(OBJDIR)/utf8.o $(OBJDIR)/portable.o
COMP_OBJS = $(OBJDIR)/editor.o $(OBJDIR)/undo.o $(OBJDIR)/layout.o $(OBJDIR)/ed_attr.o $(OBJDIR)/fmt_rtf.o $(OBJDIR)/fmt_wp4.o $(OBJDIR)/config.o $(OBJDIR)/editor_helper.o
UI_OBJS   = $(OBJDIR)/te_app.o $(OBJDIR)/ui_editor.o $(OBJDIR)/ui_view.o $(OBJDIR)/ui_keys.o $(OBJDIR)/ui_editor_helper.o $(OBJDIR)/ui_popup.o \
            $(OBJDIR)/ui_files.o $(OBJDIR)/ui_setup.o $(OBJDIR)/ui_glyph_picker.o \
            $(OBJDIR)/tabs.o $(OBJDIR)/wm.o $(OBJDIR)/ui_tabs.o $(OBJDIR)/ui_mouse.o $(OBJDIR)/ui_assist.o \
            $(OBJDIR)/ui_syntax.o

# spell_utils.o is always needed (te_is_word_char used by ui_mouse.c)
SPELL_UTILS_OBJS = $(OBJDIR)/spell_utils.o
            
ifeq ($(USE_HUNSPELL),1)
UI_OBJS   += $(OBJDIR)/ui_spell.o
endif
ifeq ($(USE_HYPHEN),1)
UI_OBJS   += $(OBJDIR)/ui_hyph.o
endif
ifeq ($(USE_MYTHES),1)
UI_OBJS   += $(OBJDIR)/ui_thes.o
endif
ifeq ($(USE_TRANSLATE),1)
UI_OBJS   += $(OBJDIR)/ui_translate.o
ifeq ($(USE_STARDICT),1)
UI_OBJS   += $(OBJDIR)/ui_dict.o
UI_OBJS   += $(OBJDIR)/ui_dict_picker.o
UI_OBJS   += $(OBJDIR)/ui_dict_reverse.o
endif
endif
ifeq ($(USE_TTS),1)
UI_OBJS   += $(OBJDIR)/ui_tts.o
endif
ALL_OBJS = $(CORE_OBJS) $(COMP_OBJS) $(UI_OBJS) $(SPELL_UTILS_OBJS) $(SPELL_OBJS) $(HYPH_OBJS) $(THES_OBJS) $(GRAMMAR_OBJS) $(TRANSLATE_OBJS) $(TTS_OBJS)

all: $(TARGET) tinyedit

$(TARGET): $(ALL_OBJS)
	$(AR) rcs $@ $(ALL_OBJS)

# Create obj directory
$(OBJDIR):
	mkdir -p $(OBJDIR)

# Core library objects
$(OBJDIR)/charset.o: $(COREDIR)/charset.c $(COREDIR)/charset.h $(COREDIR)/utf8.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/clipboard.o: $(COREDIR)/clipboard.c $(COREDIR)/clipboard.h $(COREDIR)/portable.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/keys.o: $(COREDIR)/keys.c $(COREDIR)/keys.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/search.o: $(COREDIR)/search.c $(COREDIR)/search.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/utf8.o: $(COREDIR)/utf8.c $(COREDIR)/utf8.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/portable.o: $(COREDIR)/portable.c $(COREDIR)/portable.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

# Component objects
$(OBJDIR)/editor.o: $(COMPDIR)/editor.c $(COMPDIR)/editor.h $(COMPDIR)/ed_attr.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/undo.o: $(COMPDIR)/undo.c $(COMPDIR)/undo.h $(COMPDIR)/editor.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/layout.o: $(COMPDIR)/layout.c $(COMPDIR)/layout.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@



$(OBJDIR)/ed_attr.o: $(COMPDIR)/ed_attr.c $(COMPDIR)/ed_attr.h $(COMPDIR)/editor.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $(COMPDIR)/ed_attr.c -o $@

$(OBJDIR)/fmt_rtf.o: $(COMPDIR)/fmt_rtf.c $(COMPDIR)/fmt_rtf.h $(COMPDIR)/ed_attr.h $(COMPDIR)/editor.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $(COMPDIR)/fmt_rtf.c -o $@

$(OBJDIR)/fmt_wp4.o: $(COMPDIR)/fmt_wp4.c $(COMPDIR)/fmt_wp4.h $(COMPDIR)/ed_attr.h $(COMPDIR)/editor.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $(COMPDIR)/fmt_wp4.c -o $@

$(OBJDIR)/editor_helper.o: $(COMPDIR)/editor_helper.c $(COMPDIR)/editor.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/config.o: $(COMPDIR)/config.c $(COMPDIR)/config.h $(COREDIR)/charset.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

# UI objects
$(OBJDIR)/te_app.o: $(UIDIR)/te_app.c $(UIDIR)/te.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_keys.o: $(UIDIR)/ui_keys.c $(UIDIR)/ui_keys.h $(UIDIR)/te.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_view.o: $(UIDIR)/ui_view.c $(UIDIR)/ui_view.h $(UIDIR)/te.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_editor.o: $(UIDIR)/ui_editor.c $(UIDIR)/te.h $(UIDIR)/ui_editor_helper.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_editor_helper.o: $(UIDIR)/ui_editor_helper.c $(UIDIR)/te.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_popup.o: $(UIDIR)/ui_popup.c $(UIDIR)/te.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_files.o: $(UIDIR)/ui_files.c $(UIDIR)/ui_files.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_setup.o: $(UIDIR)/ui_setup.c $(UIDIR)/ui_setup.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_glyph_picker.o: $(UIDIR)/ui_glyph_picker.c $(UIDIR)/ui_glyph_picker.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/tabs.o: $(UIDIR)/tabs.c $(UIDIR)/tabs.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/wm.o: $(UIDIR)/wm.c $(UIDIR)/wm.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_tabs.o: $(UIDIR)/ui_tabs.c $(UIDIR)/te.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_mouse.o: $(UIDIR)/ui_mouse.c $(UIDIR)/ui_mouse.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_assist.o: $(UIDIR)/ui_assist.c $(UIDIR)/ui_assist.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_syntax.o: $(UIDIR)/ui_syntax.c $(UIDIR)/ui_syntax.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

# spell_utils.o is always needed (te_is_word_char used by ui_mouse.c)
$(OBJDIR)/spell_utils.o: $(HERE)spellchecker/spell_utils.c $(HERE)spellchecker/spell_priv.h $(HERE)spellchecker/spell.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

ifeq ($(USE_HUNSPELL),1)
$(OBJDIR)/ui_spell.o: $(UIDIR)/ui_spell.c $(UIDIR)/ui_spell.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
endif

ifeq ($(USE_HYPHEN),1)
$(OBJDIR)/ui_hyph.o: $(UIDIR)/ui_hyph.c $(UIDIR)/ui_hyph.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
endif

ifeq ($(USE_MYTHES),1)
$(OBJDIR)/ui_thes.o: $(UIDIR)/ui_thes.c $(UIDIR)/ui_thes.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
endif
ifeq ($(USE_TRANSLATE),1)
$(OBJDIR)/ui_translate.o: $(UIDIR)/ui_translate.c $(UIDIR)/ui_translate.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
ifeq ($(USE_STARDICT),1)
$(OBJDIR)/ui_dict.o: $(UIDIR)/ui_dict.c $(UIDIR)/ui_dict.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
$(OBJDIR)/ui_dict_picker.o: $(UIDIR)/ui_dict_picker.c $(UIDIR)/ui_dict_picker.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
$(OBJDIR)/ui_dict_reverse.o: $(UIDIR)/ui_dict_reverse.c $(UIDIR)/ui_dict_reverse.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
endif
endif

# TTS UI glue (only if USE_TTS=1)
ifeq ($(USE_TTS),1)
$(OBJDIR)/ui_tts.o: $(UIDIR)/ui_tts.c $(UIDIR)/ui_tts.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
endif

# Spell checker object (only if USE_HUNSPELL=1)
$(OBJDIR)/spell.o: $(HERE)spell/spell.c $(HERE)spell/spell.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

# Hyphenation backend (only if USE_HYPHEN=1)
$(OBJDIR)/hyph.o: $(HERE)hyph_wrap/hyph_wrap.c $(HERE)hyph_wrap/hyph_wrap.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

# Thesaurus backend (only if USE_MYTHES=1; C++)
$(OBJDIR)/thes.o: $(HERE)thes/thes.cpp $(HERE)thes/thes.h | $(OBJDIR)
	$(CXX) $(CXXFLAGS) $(CDEFS) -c $< -o $@

# Grammar checker objects (only if USE_GRAMMAR=1)
GRAMPRIV = $(HERE)grammar/grammar.h $(HERE)grammar/grammar_priv.h

$(OBJDIR)/grammar_utils.o: $(HERE)grammar/grammar_utils.c $(GRAMPRIV) | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/grammar_cache.o: $(HERE)grammar/grammar_cache.c $(GRAMPRIV) | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/grammar_rules.o: $(HERE)grammar/grammar_rules.c $(GRAMPRIV) | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/grammar_core.o: $(HERE)grammar/grammar_core.c $(GRAMPRIV) | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/grammar_api.o: $(HERE)grammar/grammar_api.c $(GRAMPRIV) | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/ui_grammar.o: $(UIDIR)/ui_grammar.c $(UIDIR)/ui_grammar.h $(GRAMPRIV) | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

# Translator objects (only if USE_TRANSLATE=1)
ifeq ($(USE_TRANSLATE),1)
$(OBJDIR)/translate.o: $(HERE)translate/translate.c $(HERE)translate/translate.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/translate_http.o: $(HERE)translate/translate_http.c $(HERE)translate/translate.h $(HERE)translate/http_client.h $(HERE)translate/json_utils.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/http_client.o: $(HERE)translate/http_client.c $(HERE)translate/http_client.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/json_utils.o: $(HERE)translate/json_utils.c $(HERE)translate/json_utils.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

ifeq ($(USE_STARDICT),1)
$(OBJDIR)/translate_stardict.o: $(HERE)translate/translate_stardict.c $(HERE)translate/translate_stardict.h $(COREDIR)/portable.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
endif
endif

# TTS backend objects (only if USE_TTS=1).
# On Unix we compile tts.c (backend-agnostic core) and tts_espeak.c
# (subprocess dispatcher). tts_amiga.c and tts_sapi.c are guarded by
# #ifdef and produce empty objects on Unix, so we skip them.
ifeq ($(USE_TTS),1)
$(OBJDIR)/tts.o: $(HERE)tts/tts.c $(HERE)tts/tts.h $(HERE)tts/tts_backend.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(OBJDIR)/tts_espeak.o: $(HERE)tts/tts_espeak.c $(HERE)tts/tts.h $(HERE)tts/tts_backend.h | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@
endif

# Application
TINYEDIT = $(HERE)tinyedit

tinyedit: $(TINYEDIT)

# Always link with C++ driver if either Hunspell or MyThes (both can
# pull in C++ runtime) -- keep the existing branching pattern.
ifneq ($(USE_HUNSPELL)$(USE_MYTHES),00)
$(OBJDIR)/main.o: $(HERE)main.c | $(OBJDIR)
	$(CC) $(CFLAGS) $(CDEFS) -c $< -o $@

$(TINYEDIT): $(OBJDIR)/main.o $(TARGET) $(ALL_OBJS)
	$(CXX) $(CFLAGS) $(CDEFS) $(OBJDIR)/main.o $(ALL_OBJS) $(TARGET) \
	      -o $@ $(NCURSES_LIB) $(HUNSPELL_LIB) $(HYPHEN_LIB) $(MYTHES_LIB) $(TRANSLATE_LIB)
else
$(TINYEDIT): $(HERE)main.c $(TARGET) $(ALL_OBJS)
	$(CC) $(CFLAGS) $(CDEFS) $(HERE)main.c $(ALL_OBJS) $(TARGET) \
	      -o $@ $(NCURSES_LIB) $(HYPHEN_LIB) $(TRANSLATE_LIB)
endif

clean:
	rm -rf $(OBJDIR) $(TARGET) $(TINYEDIT)

.PHONY: all clean

